// El Club de La Colmena - Sistema de Gestión de Donadores
// Asociación Civil sin fines de lucro

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =====================================================
// USUARIOS Y ROLES
// =====================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("bee") // "admin" o "bee"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relaciones
  bee       Bee?
}

// =====================================================
// ABEJAS (SOCIOS/DONADORES)
// =====================================================

model Bee {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id])
  
  // Datos personales
  cedula              String   @unique  // Cédula de identidad
  phone               String            // Teléfono para pago móvil
  address             String?           // Dirección
  birthDate           DateTime?         // Fecha de nacimiento
  
  // Datos de afiliación
  affiliationNumber   String   @unique  // Número de afiliación (ABEJA-0001-2024)
  referredByCode      String?           // Código de quien lo refirió
  referredByBeeId     String?           // ID de la abeja que lo refirió
  
  // Estado
  isActive            Boolean  @default(false) // Se activa al pagar $2
  activationDate      DateTime?         // Fecha de activación ($2)
  activationPaid      Boolean  @default(false)
  
  // Fechas de control
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  // Relaciones
  actions             Action[]
  giftActionsGiven    GiftAction[]      @relation("GiftActionGiver")
  giftActionsReceived GiftAction[]      @relation("GiftActionReceiver")
  payments            Payment[]
  raffleTickets       RaffleTicket[]
  raffleWins          RaffleWinner[]
  bankAccount         BankAccount?
  referredBees        Bee[]             @relation("BeeReferral")
  referrer            Bee?              @relation("BeeReferral", fields: [referredByBeeId], references: [id])
}

// =====================================================
// ACCIONES (Carga Accionaria)
// =====================================================

model Action {
  id              String   @id @default(cuid())
  beeId           String
  bee             Bee      @relation(fields: [beeId], references: [id])
  
  // Tipo de acción
  type            String   // "activation", "monthly", "gift_received", "bonus_referral"
  description     String
  
  // Valores
  quantity        Int      @default(1)
  
  // Referencia al origen
  referenceId     String?  // ID del pago o regalo relacionado
  
  createdAt       DateTime @default(now())
}

// =====================================================
// ACCIONES DE REGALO (Sistema Viral)
// =====================================================

model GiftAction {
  id              String   @id @default(cuid())
  
  // Quien da el regalo
  giverBeeId      String
  giverBee        Bee      @relation("GiftActionGiver", fields: [giverBeeId], references: [id])
  
  // Quien recibe el regalo (cuando se activa)
  receiverBeeId   String?
  receiverBee     Bee?     @relation("GiftActionReceiver", fields: [receiverBeeId], references: [id])
  
  // Código único para compartir
  giftCode        String   @unique
  
  // Estado
  status          String   @default("available") // "available", "pending", "activated"
  activatedAt     DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// =====================================================
// PAGOS (Activación y Cuotas)
// =====================================================

model Payment {
  id              String   @id @default(cuid())
  beeId           String
  bee             Bee      @relation(fields: [beeId], references: [id])
  
  // Tipo de pago
  type            String   // "activation" ($2 único) o "monthly" ($2 mensual)
  
  // Monto en USD
  amount          Float    @default(2.0)
  
  // Estado
  status          String   @default("pending") // "pending", "approved", "rejected"
  
  // Período (para cuotas mensuales)
  periodMonth     Int?     // 1-12
  periodYear      Int?     // 2024, 2025...
  
  // Datos del comprobante de pago
  referenceNumber String?  // Número de referencia del pago móvil
  payerName       String?  // Nombre del pagador
  paymentProofImage String? // Imagen del comprobante en base64
  
  // Tasa BCV al momento del pago
  bcvRate         Float?   // Tasa del dólar BCV al momento del pago
  amountVes       Float?   // Monto pagado en bolívares
  
  // Verificación
  reviewedBy      String?  // ID del admin que revisó
  reviewedAt      DateTime?
  rejectionReason String?  // Razón del rechazo
  
  // Fechas
  dueDate         DateTime?
  paidAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// =====================================================
// CUENTA BANCARIA DE LA ORGANIZACIÓN
// =====================================================

model OrganizationBankAccount {
  id              String   @id @default(cuid())
  
  // Datos de la cuenta para recibir pagos
  accountHolder   String   // Titular: Sara Mestre
  bankName        String   // Banco: Banco del Caribe
  phone           String   // Teléfono Pago Móvil: 0414 0379406
  rif             String   // RIF: J297354239
  accountType     String   @default("corriente")
  
  // Activo
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// =====================================================
// CUENTAS BANCARIAS DE LAS ABEJAS (Para recibir premios)
// =====================================================

model BankAccount {
  id              String   @id @default(cuid())
  beeId           String   @unique
  bee             Bee      @relation(fields: [beeId], references: [id])
  
  // Datos bancarios
  bankName        String   // Nombre del banco
  accountType     String   // "corriente", "ahorro"
  accountNumber   String   // Número de cuenta
  cedula          String   // Cédula del titular
  phone           String   // Teléfono para pago móvil
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// =====================================================
// SORTEOS
// =====================================================

model Raffle {
  id              String   @id @default(cuid())
  
  // Datos del sorteo
  name            String
  description     String?
  type            String   // "weekly", "monthly", "semester", "annual"
  
  // Premio
  prizeAmount     Float
  prizeDescription String?
  numberOfWinners Int      @default(1)
  
  // Estado
  status          String   @default("scheduled") // "scheduled", "active", "completed"
  
  // Fechas
  scheduledDate   DateTime
  executedAt      DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relaciones
  tickets         RaffleTicket[]
  winners         RaffleWinner[]
}

// =====================================================
// TICKETS DE SORTEO
// =====================================================

model RaffleTicket {
  id              String   @id @default(cuid())
  raffleId        String
  raffle          Raffle   @relation(fields: [raffleId], references: [id])
  beeId           String
  bee             Bee      @relation(fields: [beeId], references: [id])
  
  // Cantidad de tickets según acciones
  ticketCount     Int      @default(1)
  
  // Números de ticket asignados
  ticketNumbers   String   // JSON array con los números asignados
  
  createdAt       DateTime @default(now())
}

// =====================================================
// GANADORES DE SORTEOS
// =====================================================

model RaffleWinner {
  id              String   @id @default(cuid())
  raffleId        String
  raffle          Raffle   @relation(fields: [raffleId], references: [id])
  beeId           String
  bee             Bee      @relation(fields: [beeId], references: [id])
  
  // Premio ganado
  prizeAmount     Float
  prizePosition   Int      @default(1) // 1er, 2do, 3er lugar...
  
  // Estado del pago
  paymentStatus   String   @default("pending") // "pending", "paid"
  paymentReference String?
  paidAt          DateTime?
  
  createdAt       DateTime @default(now())
}

// =====================================================
// NIÑOS BENEFICIADOS
// =====================================================

model Child {
  id              String   @id @default(cuid())
  
  // Datos del niño
  name            String
  cedula          String?
  birthDate       DateTime?
  grade           String?  // Grado escolar
  school          String?  // Escuela
  
  // Datos del representante
  representativeName  String
  representativePhone String
  representativeEmail String?
  
  // Estado de la beca
  status          String   @default("active") // "active", "graduated", "inactive"
  
  // Beneficios
  monthlyBenefit  Float?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// =====================================================
// CONFIGURACIÓN DEL SISTEMA
// =====================================================

model Setting {
  id              String   @id @default(cuid())
  key             String   @unique
  value           String
  description     String?
  
  updatedAt       DateTime @updatedAt
}

// =====================================================
// LOG DE ACTIVIDADES
// =====================================================

model ActivityLog {
  id              String   @id @default(cuid())
  userId          String?
  action          String
  details         String?  // JSON con detalles adicionales
  
  createdAt       DateTime @default(now())
}

// =====================================================
// TASA BCV (Historial)
// =====================================================

model ExchangeRate {
  id              String   @id @default(cuid())
  rate            Float    // Tasa BCV
  date            DateTime @default(now())
  source          String   @default("bcv") // Fuente de la tasa
  
  createdAt       DateTime @default(now())
}
