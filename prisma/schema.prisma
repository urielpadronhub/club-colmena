// El Club de La Colmena - Sistema de Gestión de Donadores
// Asociación Civil sin fines de lucro

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// USUARIOS Y ROLES
// =====================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("bee") // "admin" o "bee"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  bee Bee?
}

// =====================================================
// ABEJAS (SOCIOS/DONADORES)
// =====================================================

model Bee {
  id        String @id @default(cuid())
  userId    String @unique
  user      User   @relation(fields: [userId], references: [id])

  // Datos personales
  cedula String @unique // Cédula de identidad
  phone  String // Teléfono para pago móvil
  address String? // Dirección
  birthDate DateTime? // Fecha de nacimiento

  // Tipo de socio (4 niveles)
  memberType String @default("formal") // "presidente", "elite", "fundador", "formal"
  eliteNumber Int? // Número de Elite (1-100)
  founderNumber Int? // Número de Fundador (1-500)

  // ADN (Red de referidos)
  parentEliteId String? // ID del Elite patrocinador
  parentFounderId String? // ID del Fundador patrocinador
  totalDownline Int @default(0) // Total de referidos en la red

  // Datos de afiliación
  affiliationNumber String @unique // Número de afiliación (Elite#-Fundador#-Cedula)
  referredByCode String? // Código de quien lo refirió

  // Estado
  isActive Boolean @default(true)
  activationDate DateTime? // Fecha de activación ($2)
  activationPaid Boolean @default(false)

  // Fechas de control
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  actions             Action[]
  giftActionsGiven    GiftAction[] @relation("GiftActionGiver")
  giftActionsReceived GiftAction[] @relation("GiftActionReceiver")
  payments            Payment[]
  raffleTickets       RaffleTicket[]
  raffleWins          RaffleWinner[]
  bankAccount         BankAccount?
}

// =====================================================
// ACCIONES (Carga Accionaria)
// =====================================================

model Action {
  id      String @id @default(cuid())
  beeId   String
  bee     Bee    @relation(fields: [beeId], references: [id])

  // Tipo de acción
  type        String // "activation", "monthly", "gift_received", "bonus_referral"
  description String

  // Valores
  quantity Int @default(1)

  // Referencia al origen
  referenceId String? // ID del pago o regalo relacionado

  createdAt DateTime @default(now())
}

// =====================================================
// ACCIONES DE REGALO (Sistema Viral)
// =====================================================

model GiftAction {
  id String @id @default(cuid())

  // Quien da el regalo
  giverBeeId String
  giverBee   Bee @relation("GiftActionGiver", fields: [giverBeeId], references: [id])

  // Quien recibe el regalo (cuando se activa)
  receiverBeeId String?
  receiverBee   Bee? @relation("GiftActionReceiver", fields: [receiverBeeId], references: [id])

  // Código único para compartir
  giftCode String @unique

  // Estado
  status      String @default("available") // "available", "pending", "activated"
  activatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =====================================================
// PAGOS (Activación y Cuotas)
// =====================================================

model Payment {
  id     String @id @default(cuid())
  beeId  String
  bee    Bee    @relation(fields: [beeId], references: [id])

  // Tipo de pago
  type String // "activation" ($2 único) o "monthly" ($2 mensual)

  // Monto
  amount Float @default(2.0)

  // Estado
  status String @default("pending") // "pending", "completed", "failed"

  // Período (para cuotas mensuales)
  periodMonth Int? // 1-12
  periodYear  Int? // 2024, 2025...

  // Referencia de pago
  paymentReference String? // Número de referencia bancaria

  // Fechas
  dueDate   DateTime?
  paidAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =====================================================
// CUENTAS BANCARIAS (Para Pago Móvil)
// =====================================================

model BankAccount {
  id     String @id @default(cuid())
  beeId  String @unique
  bee    Bee    @relation(fields: [beeId], references: [id])

  // Datos bancarios
  bankName      String // Nombre del banco
  accountType   String // "corriente", "ahorro"
  accountNumber String // Número de cuenta
  cedula        String // Cédula del titular
  phone         String // Teléfono para pago móvil

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =====================================================
// SORTEOS
// =====================================================

model Raffle {
  id String @id @default(cuid())

  // Datos del sorteo
  name        String
  description String?
  type        String // "weekly", "monthly", "semester", "annual"

  // Premio
  prizeAmount      Float
  prizeDescription String?
  numberOfWinners  Int @default(1)

  // Estado
  status String @default("scheduled") // "scheduled", "active", "completed"

  // Fechas
  scheduledDate DateTime
  executedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  tickets RaffleTicket[]
  winners RaffleWinner[]
}

// =====================================================
// TICKETS DE SORTEO
// =====================================================

model RaffleTicket {
  id        String @id @default(cuid())
  raffleId  String
  raffle    Raffle @relation(fields: [raffleId], references: [id])
  beeId     String
  bee       Bee    @relation(fields: [beeId], references: [id])

  // Cantidad de tickets según acciones
  ticketCount Int @default(1)

  // Números de ticket asignados
  ticketNumbers String // JSON array con los números asignados

  createdAt DateTime @default(now())
}

// =====================================================
// GANADORES DE SORTEOS
// =====================================================

model RaffleWinner {
  id        String @id @default(cuid())
  raffleId  String
  raffle    Raffle @relation(fields: [raffleId], references: [id])
  beeId     String
  bee       Bee    @relation(fields: [beeId], references: [id])

  // Premio ganado
  prizeAmount   Float
  prizePosition Int @default(1) // 1er, 2do, 3er lugar...

  // Estado del pago
  paymentStatus   String @default("pending") // "pending", "paid"
  paymentReference String?
  paidAt          DateTime?

  createdAt DateTime @default(now())
}

// =====================================================
// NIÑOS BENEFICIADOS
// =====================================================

model Child {
  id String @id @default(cuid())

  // Datos del niño
  name      String
  cedula    String?
  birthDate DateTime?
  grade     String? // Grado escolar
  school    String? // Escuela

  // Datos del representante
  representativeName  String
  representativePhone String
  representativeEmail String?

  // Estado de la beca
  status String @default("active") // "active", "graduated", "inactive"

  // Beneficios
  monthlyBenefit Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =====================================================
// CONFIGURACIÓN DEL SISTEMA
// =====================================================

model Setting {
  id          String @id @default(cuid())
  key         String @unique
  value       String
  description String?

  updatedAt DateTime @updatedAt
}

// =====================================================
// LOG DE ACTIVIDADES
// =====================================================

model ActivityLog {
  id     String @id @default(cuid())
  userId String?
  action String
  details String? // JSON con detalles adicionales

  createdAt DateTime @default(now())
}
